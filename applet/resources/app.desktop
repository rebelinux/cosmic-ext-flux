[Desktop Entry]
Type=Application
Name=Flux
Comment=Control the Flux live wallpaper
Icon=io.github.franz_net.CosmicExtAppletFlux
Exec=cosmic-ext-applet-flux %F
Terminal=false
StartupNotify=true
NoDisplay=true
Categories=COSMIC;
Keywords=COSMIC;wallpaper;live;flux;
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
